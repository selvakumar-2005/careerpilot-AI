{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd careerpilot-backend && mvn clean package -DskipTests"
  },
  "deploy": {
    "startCommand": "java -Dspring.profiles.active=prod -jar careerpilot-backend/target/careerpilot-backend-1.0.0.jar",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
