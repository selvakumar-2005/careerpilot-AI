{
  "info": {
    "_postman_id": "careerpilot-ai-part1",
    "name": "CareerPilot AI — Part 1",
    "description": "Complete API collection for CareerPilot AI Part 1. Run Register first, then Login to auto-capture the JWT token for all protected requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string",
      "description": "Auto-populated after Login or Register"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('jwt_token', json.data.token);",
                  "  pm.test('Registration successful', () => pm.expect(json.success).to.be.true);",
                  "  pm.test('Token received', () => pm.expect(json.data.token).to.be.a('string'));",
                  "  pm.test('User role is STUDENT', () => pm.expect(json.data.user.role).to.eql('STUDENT'));",
                  "  console.log('Token saved:', json.data.token.substring(0, 30) + '...');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Test Student\",\n  \"email\": \"teststudent@example.com\",\n  \"password\": \"Test@1234\",\n  \"confirmPassword\": \"Test@1234\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register a new STUDENT account. JWT token is automatically saved to the collection variable `jwt_token`."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('jwt_token', json.data.token);",
                  "  pm.test('Login successful', () => pm.expect(json.success).to.be.true);",
                  "  pm.test('Token present', () => pm.expect(json.data.token).to.be.a('string'));",
                  "  pm.test('User returned', () => pm.expect(json.data.user.email).to.be.a('string'));",
                  "  console.log('Token saved:', json.data.token.substring(0, 30) + '...');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@careerpilot.com\",\n  \"password\": \"Admin@1234\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login with existing credentials. JWT token is automatically saved to `jwt_token`."
          }
        },
        {
          "name": "Login — Wrong Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('success is false', () => pm.expect(pm.response.json().success).to.be.false);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@careerpilot.com\",\n  \"password\": \"WrongPassword1!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Verify that wrong credentials return 401."
          }
        },
        {
          "name": "Register — Validation Error",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Has field errors', () => pm.expect(pm.response.json().data).to.be.an('object'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"\",\n  \"email\": \"not-an-email\",\n  \"password\": \"weak\",\n  \"confirmPassword\": \"mismatch\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Verify that invalid input returns 400 with field-level error map."
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Logout successful', () => pm.expect(pm.response.json().success).to.be.true);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "Stateless logout. Client must delete the JWT from localStorage."
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Current User (me)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('success true', () => pm.expect(pm.response.json().success).to.be.true);",
                  "pm.test('Has user data', () => {",
                  "  const user = pm.response.json().data;",
                  "  pm.expect(user.id).to.be.a('number');",
                  "  pm.expect(user.email).to.be.a('string');",
                  "  pm.expect(user.role).to.be.oneOf(['STUDENT', 'ADMIN']);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/me",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "me"]
            },
            "description": "Fetch the profile of the currently authenticated user. Requires Bearer token."
          }
        },
        {
          "name": "Get Current User — No Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('Access denied message', () => {",
                  "  pm.expect(pm.response.json().message).to.include('Access denied');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users/me",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "me"]
            },
            "description": "Verify that missing token returns 401 JSON (not HTML error page)."
          }
        },
        {
          "name": "Get User By ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 or 404', () => {",
                  "  pm.expect([200, 404]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/1",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "1"]
            },
            "description": "Fetch a user by their numeric ID. Change `1` to any valid user ID."
          }
        },
        {
          "name": "Get User By ID — Not Found",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));",
                  "pm.test('success false', () => pm.expect(pm.response.json().success).to.be.false);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/users/9999",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "9999"]
            },
            "description": "Verify that a non-existent user ID returns a 404 JSON response."
          }
        }
      ]
    }
  ]
}
