        {
          "name": "Analyze Code",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"problem_description\": \"Reverse a linked list. Given the head of a singly linked list, reverse the list, and return the reversed list.\",\n  \"code\": \"class Solution {\\n    public ListNode reverseList(ListNode head) {\\n        ListNode prev = null;\\n        ListNode curr = head;\\n        while (curr != null) {\\n            ListNode temp = curr.next;\\n            curr.next = prev;\\n            prev = curr;\\n            curr = temp;\\n        }\\n        return prev;\\n    }\\n}\",\n  \"language\": \"java\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/ai/coding/analyze",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "ai", "coding", "analyze"]
            }
